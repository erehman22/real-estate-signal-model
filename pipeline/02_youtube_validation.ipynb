 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# YouTube Signal Validation\n",
    "\n",
    "Validates YouTube travel video upload patterns as a leading indicator of real estate price booms.\n",
    "\n",
    "Key signals to look for:\n",
    "- **Upload count acceleration** — when did travel content about this place start growing?\n",
    "- **Weighted reach breakout** — when did mid-sized channels start covering it?\n",
    "- **Mainstream channel arrival** — when did large channels (>100k subs) show up?\n",
    "- **View velocity on early cohorts** — which early video batches found large audiences?\n",
    "\n",
    "The hypothesis: weighted_reach (upload × channel size) fires 2–4 years before price inflection,\n",
    "with mainstream channel arrival as a T2 legitimisation confirmation signal ~1–2 years out."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import yaml\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.ticker as mticker\n",
    "import numpy as np\n",
    "from pathlib import Path\n",
    "\n",
    "CONFIG_PATH   = Path('../config/locations.yaml')\n",
    "PROCESSED_DIR = Path('../data/processed/youtube')\n",
    "RAW_DIR       = Path('../data/raw/youtube')\n",
    "\n",
    "with open(CONFIG_PATH) as f:\n",
    "    locations = yaml.safe_load(f)['locations']\n",
    "\n",
    "print(f'Loaded {len(locations)} locations')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def load_features(loc_id):\n",
    "    path = PROCESSED_DIR / f'{loc_id}_youtube_features.csv'\n",
    "    if not path.exists():\n",
    "        print(f'No processed data for {loc_id}')\n",
    "        return None\n",
    "    return pd.read_csv(path, index_col=0, parse_dates=True)\n",
    "\n",
    "\n",
    "def plot_location(loc_id, loc_name, inflection_year):\n",
    "    df = load_features(loc_id)\n",
    "    if df is None:\n",
    "        return\n",
    "\n",
    "    fig, axes = plt.subplots(4, 1, figsize=(14, 16), sharex=True)\n",
    "    fig.suptitle(\n",
    "        f'{loc_name} — YouTube signal vs price inflection ({inflection_year})',\n",
    "        fontsize=14, fontweight='bold'\n",
    "    )\n",
    "\n",
    "    inflection_line = pd.Timestamp(f'{inflection_year}-01-01')\n",
    "    vline_kw = dict(color='red', linestyle='--', linewidth=1.5,\n",
    "                    label=f'Price inflection ({inflection_year})')\n",
    "\n",
    "    # ── Panel 1: Upload count ─────────────────────────────────────────────\n",
    "    ax = axes[0]\n",
    "    ax.bar(df.index, df['upload_count'], width=80, color='royalblue',\n",
    "           alpha=0.5, label='Uploads/quarter')\n",
    "    if 'upload_count_roll4q' in df.columns:\n",
    "        ax.plot(df.index, df['upload_count_roll4q'], color='navy',\n",
    "                linewidth=2, label='4q rolling avg')\n",
    "    ax.axvline(inflection_line, **vline_kw)\n",
    "    ax.set_ylabel('Video count')\n",
    "    ax.set_title('Travel video uploads per quarter')\n",
    "    ax.legend(fontsize=8)\n",
    "\n",
    "    # ── Panel 2: Weighted reach ───────────────────────────────────────────\n",
    "    ax = axes[1]\n",
    "    if 'weighted_reach' in df.columns:\n",
    "        ax.bar(df.index, df['weighted_reach'] / 1e6, width=80, color='darkorange',\n",
    "               alpha=0.5, label='Weighted reach (M)')\n",
    "    if 'weighted_reach_roll4q' in df.columns:\n",
    "        ax.plot(df.index, df['weighted_reach_roll4q'] / 1e6, color='saddlebrown',\n",
    "                linewidth=2, label='4q rolling avg')\n",
    "    ax.axvline(inflection_line, **vline_kw)\n",
    "    ax.set_ylabel('Reach (millions)')\n",
    "    ax.set_title('Weighted reach: uploads × median channel subscribers')\n",
    "    ax.legend(fontsize=8)\n",
    "\n",
    "    # ── Panel 3: % large channels ─────────────────────────────────────────\n",
    "    ax = axes[2]\n",
    "    if 'pct_large_channels' in df.columns:\n",
    "        ax.plot(df.index, df['pct_large_channels'], color='purple',\n",
    "                linewidth=1, alpha=0.4, label='Raw %')\n",
    "    if 'pct_large_channels_roll4q' in df.columns:\n",
    "        ax.plot(df.index, df['pct_large_channels_roll4q'], color='purple',\n",
    "                linewidth=2, label='4q rolling avg')\n",
    "    ax.axhline(30, color='gray', linestyle=':', linewidth=1,\n",
    "               label='30% threshold (mainstream arrival)')\n",
    "    ax.axvline(inflection_line, **vline_kw)\n",
    "    ax.set_ylabel('% large channels')\n",
    "    ax.set_title('% uploads from channels >100k subscribers (mainstream legitimisation)')\n",
    "    ax.legend(fontsize=8)\n",
    "\n",
    "    # ── Panel 4: Z-score (weighted reach) ────────────────────────────────\n",
    "    ax = axes[3]\n",
    "    z_col = 'weighted_reach_roll4q_zscore'\n",
    "    if z_col in df.columns:\n",
    "        ax.plot(df.index, df[z_col], color='green', linewidth=2,\n",
    "                label='Z-score (weighted reach, smoothed)')\n",
    "        ax.axhline(2.0, color='orange', linestyle=':', linewidth=1.5,\n",
    "                   label='Z=2 threshold')\n",
    "        ax.fill_between(df.index, 2.0, df[z_col].clip(lower=2.0),\n",
    "                        alpha=0.2, color='orange')\n",
    "    ax.axvline(inflection_line, **vline_kw)\n",
    "    ax.set_ylabel('Z-score')\n",
    "    ax.set_title('Standardised weighted reach vs 2006–2014 baseline')\n",
    "    ax.legend(fontsize=8)\n",
    "    ax.xaxis.set_major_locator(mticker.MaxNLocator(12))\n",
    "\n",
    "    plt.tight_layout()\n",
    "    out = PROCESSED_DIR / f'{loc_id}_youtube_validation.png'\n",
    "    plt.savefig(out, dpi=150, bbox_inches='tight')\n",
    "    plt.show()\n",
    "    print(f'Saved → {out}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Plot all locations\n",
    "for loc in locations:\n",
    "    plot_location(loc['id'], loc['name'], loc['price_inflection_year'])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cross-location summary\n",
    "summary_path = PROCESSED_DIR / '_signal_summary.csv'\n",
    "if summary_path.exists():\n",
    "    summary = pd.read_csv(summary_path)\n",
    "    print('\\n── YouTube signal lead times ───────────────────────────────────')\n",
    "    print(summary[[\n",
    "        'location_name', 'price_inflection_year',\n",
    "        'best_break_year', 'z_fire_year', 'mainstream_arrival_year',\n",
    "        'lead_time_break_yrs', 'lead_time_z_yrs', 'lead_time_mainstream_yrs'\n",
    "    ]].to_string(index=False))\n",
    "\n",
    "    valid = summary['lead_time_z_yrs'].dropna()\n",
    "    if len(valid) > 0:\n",
    "        print(f'\\nMedian lead time (z-score): {valid.median():.1f} years')\n",
    "        print(f'Mean:                       {valid.mean():.1f} years')\n",
    "        print(f'Range:                      {valid.min():.0f} – {valid.max():.0f} years')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# View the top 10 most-viewed early videos per location\n",
    "# Useful for manually validating that the signal is real\n",
    "for loc in locations:\n",
    "    loc_id   = loc['id']\n",
    "    loc_name = loc['name']\n",
    "    inflection_year = loc['price_inflection_year']\n",
    "\n",
    "    videos_path = RAW_DIR / loc_id / 'videos.csv'\n",
    "    if not videos_path.exists():\n",
    "        continue\n",
    "\n",
    "    vdf = pd.read_csv(videos_path)\n",
    "    vdf = vdf.dropna(subset=['published_year'])\n",
    "\n",
    "    # Filter to pre-inflection videos only\n",
    "    early = vdf[vdf['published_year'] < inflection_year].copy()\n",
    "    if early.empty:\n",
    "        continue\n",
    "\n",
    "    top10 = early.nlargest(10, 'view_count')[[\n",
    "        'published_year', 'title', 'channel_title',\n",
    "        'view_count', 'channel_subs'\n",
    "    ]]\n",
    "\n",
    "    print(f'\\n── {loc_name}: top 10 pre-boom videos by views ──────────────')\n",
    "    print(top10.to_string(index=False))"
   ]
  }
 ],
